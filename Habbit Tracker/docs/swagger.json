            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "schedule": {
                    "description": "конфигурация в JSON",
                    "type": "object"
                },
                "schedule_text": {
                    "description": "\"Каждый понедельник\"",
                    "type": "string"
                },
                "schedule_type": {
                    "description": "daily, weekly, monthly, interval, custom",
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "user_id": {
                    "description": "привязываем привычку к пользователю",
                    "type": "string"
                }
            }
        },
        "cmd_server.LoginRequest": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "cmd_server.LoginResponse": {
            "type": "object",
            "properties": {
                "token": {
                    "type": "string"
                },
                "user": {
                    "$ref": "#/definitions/cmd_server.User"
                }
            }
        },
        "cmd_server.RegisterRequest": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "cmd_server.User": {
            "type": "object",
