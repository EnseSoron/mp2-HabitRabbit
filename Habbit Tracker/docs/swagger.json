    "securityDefinitions": {
        "BearerAuth": {
            "description": "Для доступа к защищенным эндпоинтам необходимо добавить заголовок: Authorization: Bearer {ваш-jwt-токен}",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
