        "/register": {
            "post": {
                "description": "Создает нового пользователя в системе. Email должен быть уникальным.\nПароль должен быть минимум 6 символов.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Регистрация нового пользователя",
                "parameters": [
