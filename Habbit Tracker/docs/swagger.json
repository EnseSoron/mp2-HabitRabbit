    "definitions": {
        "cmd_server.CreateHabitRequest": {
            "type": "object",
            "required": [
                "title"
            ],
            "properties": {
                "description": {
                    "type": "string"
                },
                "schedule": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "schedule_type": {
                    "description": "daily, weekly, monthly, interval, custom",
                    "type": "string"
                },
                "title": {
                    "type": "string"
                }
            }
        },
        "cmd_server.ErrorResponse": {
            "type": "object",
